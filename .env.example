GITHUB_APP_ID=123456
GITHUB_APP_PRIVATE_KEY_FILE=/run/secrets/github-app.pem
GITHUB_WEBHOOK_SECRET=replace-with-webhook-secret
MYSQL_DSN=pr_go:change-me@tcp(mysql:3306)/pr_go?parseTime=true
OPENAI_API_KEY=sk-replace-me
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
PR_GO_PROVIDER=openai-compatible
PR_GO_ADMIN_TOKEN=replace-with-long-random-token
PR_GO_WORKER_COUNT=4
PR_GO_MAX_RETRIES=5
PR_GO_QUEUE_POLL=2s
PR_GO_ALERT_WEBHOOK_URL=
